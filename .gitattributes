# Auto detect text files and ensure LF line endings everywhere
* text=auto eol=lf

# Explicit text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.graphql text eol=lf
*.svg text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
.prettierrc* text eol=lf
.npmrc text eol=lf
.yarnrc text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Binary files (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.db binary
*.sqlite binary
*.node binary
